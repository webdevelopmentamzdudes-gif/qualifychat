NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Owner alert emails (new lead, live agent, qualified) via SMTP — e.g. Hostinger
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@amzdudes.io
SMTP_PASS=
SMTP_FROM=QualifyChat <no-reply@amzdudes.io>
# Alerts go to business Contact email, or signup email if contact email is empty.
# Local: http://localhost:3000 | Production: https://qualifychat.amzdudes.io
NEXT_PUBLIC_APP_URL=http://localhost:3000
KNOWLEDGE_MAX_FILE_MB=10
KNOWLEDGE_MAX_CHUNKS_PER_DOC=150
